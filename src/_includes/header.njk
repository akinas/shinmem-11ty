{#  src/_includes/header.njk #}
{% set homepage_url = '/' %}
{% if page.lang === 'en' %}
    {% set homepage_url = '/en/' %}
{% endif %}

<header data-role="Header" class="global-header">
  <div class="header-logo-container">
    <a href="{{ homepage_url | url }}" class="header-logo-link">
      <span class="header-logo-text">
        {% if page.lang == 'he' %}
          ש"מ <span class="logo-subtitle">[שמע מינה]</span>
        {% else %}
          ShinMem <span class="logo-subtitle">שמע מינה</span>
        {% endif %}
      </span>
    </a>
  </div>

  {# Language Switch Menu - Modern Toggle Design #}
  <div class="lang-switch-container">
    <div class="lang-switch-toggle">
      {% if page.lang == 'he' %}
        <a href="{{ '/en/' if page.url == '/' else page.url | replace('/he/', '/en/') }}" class="lang-option lang-option-inactive" data-lang="en">
          <span class="lang-code">EN</span>
          <span class="lang-name">English</span>
        </a>
        <span class="lang-option lang-option-active" data-lang="he">
          <span class="lang-code">עב</span>
          <span class="lang-name">עברית</span>
        </span>
      {% else %}
        <span class="lang-option lang-option-active" data-lang="en">
          <span class="lang-code">EN</span>
          <span class="lang-name">English</span>
        </span>
        <a href="{{ '/' if page.url == '/en/' else page.url | replace('/en/', '/he/') }}" class="lang-option lang-option-inactive" data-lang="he">
          <span class="lang-code">עב</span>
          <span class="lang-name">עברית</span>
        </a>
      {% endif %}
      <div class="lang-switch-slider"></div>
    </div>
  </div>
</header>