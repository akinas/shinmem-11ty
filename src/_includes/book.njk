{% extends "base.njk" %}

{% block title %}{{ title }} by {{ author }} | ShinMem | שמע מינה{% endblock %}
{% block og_title %}{{ title }} by {{ author }} | ShinMem | שמע מינה{% endblock %}

{% block navigation %}
<div class="book-navigation">
  <a href="{% if page.lang == 'he' %}/{% else %}/en/{% endif %}" class="back-home-link">
    ← {% if page.lang == 'he' %}חזרה לעמוד הבית{% else %}Back to Home{% endif %}
  </a>
</div>
{% endblock %}



{% block main_content %}
<main class="book-content">
  {# Hero section with book cover #}
  <div class="book-hero">
    <div class="book-cover-container">
      <img 
        src="{{ image_src }}" 
        alt="{{ title }} book cover" 
        class="book-cover-image"
        loading="lazy"
      />
    </div>
    <div class="book-info">
      <h1 class="book-title">{{ title }}{% if title_en and title_en != title %} ({{ title_en }}){% endif %}</h1>
      <p class="book-author">{{ author }}{% if year %} ({{ year }}){% endif %}</p>
      {% if misc_info %}
        <p class="book-edition">{{ misc_info }}</p>
      {% endif %}
      
      {# Book Actions - moved to hero for better UX #}
      <div class="book-actions-container">
        <div class="book-actions-hero button-group">
          {% if status == 'available' %}
            {% if hardcover_buy_now_url %}
              {# Dual edition mode - columns side-by-side #}
              <div class="buy-options-columns">
                {% if buy_now_url or il_buy_now_url %}
                  <div class="buy-column">
                    {% if buy_now_url %}
                      <a href="{{ buy_now_url }}" target="_blank" rel="noreferrer noopener" class="button">
                        {{ i18n.buy_paperback[page.lang] }}
                      </a>
                    {% endif %}
                    {% if il_buy_now_url %}
                      <a href="{{ il_buy_now_url }}" target="_blank" rel="noreferrer noopener" class="button button-secondary">
                        {{ i18n.buy_paperback_il[page.lang] }}
                      </a>
                    {% endif %}
                  </div>
                {% endif %}
                
                <div class="buy-column">
                  <a href="{{ hardcover_buy_now_url }}" target="_blank" rel="noreferrer noopener" class="button">
                    {{ i18n.buy_hardcover[page.lang] }}
                  </a>
                  {% if hardcover_il_buy_now_url %}
                    <a href="{{ hardcover_il_buy_now_url }}" target="_blank" rel="noreferrer noopener" class="button button-secondary">
                      {{ i18n.buy_hardcover_il[page.lang] }}
                    </a>
                  {% endif %}
                </div>
              </div>
            {% else %}
              {# Single edition mode (default) #}
              {% if buy_now_url %}
                <a href="{{ buy_now_url }}" target="_blank" rel="noreferrer noopener" class="button">
                  {{ i18n.buy_now[page.lang] }}
                </a>
                
                {% if il_buy_now_url %}
                  <a href="{{ il_buy_now_url }}" target="_blank" rel="noreferrer noopener" class="button button-secondary">
                    {{ i18n.buy_now_il[page.lang] }}
                  </a>
                {% endif %}
              {% endif %}
            {% endif %}
          {% else %}
            <button type="button" disabled class="button button-disabled">
              <span>{{ i18n.sold_out[page.lang] }}</span>
            </button>
          {% endif %}
          {% if read_more_url %}
            <a href="{{ read_more_url }}" target="_blank" rel="noreferrer noopener" class="button button-secondary">
              {{ i18n.read_more[page.lang] }}
            </a>
          {% endif %}
        </div>

        {% if pdf_id and pdfs[pdf_id] %}
          <div class="download-action">
            <a href="{{ pdfs[pdf_id] }}" target="_blank" rel="noreferrer noopener" class="button button-download">
              <svg class="download-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" style="margin-inline-end: 6px;">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              <span>{{ i18n.download_sample[page.lang] }}</span>
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
  
  <div class="book-main-content">
    {{ content | safe }}
  </div>
  
  {# Remove the duplicate book actions since they're now in the hero #}
</main>
{% endblock %}